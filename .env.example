# Copy this file to .env and fill in real values locally.
# NEVER commit a file containing real credentials — .env is gitignored.
# For GitHub Actions, set these under Settings -> Secrets and variables ->
# Actions -> New repository secret (same names, one secret each). Do not
# put real values in this file or anywhere else in the repo.

# --- X (Twitter) API — OAuth 1.0a user context ---------------------------
# Required by pipeline/fetch_x_data.py and diagnostics/check_x_auth.py.
# Get these from developer.x.com -> your App -> Keys and Tokens.
# Generate the Access Token/Secret AFTER setting the app's permissions
# (Read, or Read+Write if you'll post too) — tokens generated before a
# permission change are invalid and must be regenerated.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Optional — only needed if/when a bearer-token (app-only) flow is used
# instead of/alongside OAuth 1.0a. Not required by the current pipeline.
X_BEARER_TOKEN=

# --- YouTube (Data API v3 + Analytics API) — OAuth 2.0 --------------------
# Required by pipeline/fetch_youtube_data.py. One OAuth credential set powers
# BOTH the public channel/video stats and the owner-only analytics (watch
# time, impressions, traffic sources, subscriber gains).
#
# Setup (once):
#   1. console.cloud.google.com -> create/select a project.
#   2. Enable BOTH "YouTube Data API v3" and "YouTube Analytics API".
#   3. Configure the OAuth consent screen; add the channel-owner Google
#      account under "Test users".
#   4. Create an OAuth client ID of type "Desktop app" -> copy the Client ID
#      and Client secret into the two vars below.
#   5. Get the refresh token by running (with the two vars set):
#        python pipeline/youtube_oauth_setup.py
#      Sign in as the channel owner, approve, paste the code, and copy the
#      printed YOUTUBE_REFRESH_TOKEN below.
# For GitHub Actions, add all three as repo secrets (same names).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Instagram (Graph API — Business/Creator account) --------------------
# Required by pipeline/fetch_instagram_data.py. The Instagram account must be
# a Business or Creator account linked to a Facebook Page, with a Meta app.
#
# Get these by running: python pipeline/instagram_token_setup.py
#   IG_ACCESS_TOKEN         -> long-lived user token (~60 days), OR a Meta
#                              System User token (recommended: never expires,
#                              best for the unattended daily GitHub Action)
#   IG_BUSINESS_ACCOUNT_ID  -> the numeric IG user id (not the @handle)
# For GitHub Actions, add both as repo secrets (same names).
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
# Optional — pin the Graph API version (defaults to v21.0). Bump this if Meta
# sunsets that version.
# IG_API_VERSION=v21.0

# Only needed once, by pipeline/instagram_token_setup.py, to mint the token
# above — not read by the daily pipeline, so these don't need to be repo
# secrets. From developers.facebook.com -> your app.
# FB_APP_ID=
# FB_APP_SECRET=
# FB_SHORT_TOKEN=

# --- TikTok (Display API + Login Kit) — OAuth 2.0 -------------------------
# Required by pipeline/fetch_tiktok_data.py. Register an app at
# developers.tiktok.com, add the Login Kit product with scopes
# user.info.basic, user.info.profile, user.info.stats, video.list, and add
# the redirect URI http://localhost:8080/callback.
#
# Get the refresh token by running (with the key/secret set):
#   python pipeline/tiktok_oauth_setup.py
# The refresh token lasts ~365 days — re-run once a year to refresh it.
# For GitHub Actions, add all three as repo secrets (same names).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# --- LinkedIn (Company Page) ----------------------------------------------
# Used by pipeline/fetch_linkedin_data.py. Two providers, selected by
# LINKEDIN_SOURCE:
#   selenium (default) -> scrapes the company page (see caveats in README).
#   api                -> official Community Management API (implement
#                         pipeline/linkedin_api.py when you have access).
# LINKEDIN_SOURCE=selenium

# Company vanity slug or numeric id, e.g. "mangrove-ai" (from the page URL
# linkedin.com/company/<this>/). Required for the selenium provider.
LINKEDIN_COMPANY=

# Auth for the selenium provider. PREFERRED: paste your li_at session cookie
# (DevTools -> Application -> Cookies -> www.linkedin.com -> li_at). It's more
# robust and sidesteps 2FA. Treat it like a password — it grants account access.
LINKEDIN_LI_AT=
# Fallback only (more likely to trigger 2FA/security checkpoints):
# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=
# LINKEDIN_HEADLESS=true

# For the future API provider (LINKEDIN_SOURCE=api):
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_ORG_ID=

# --- HubSpot (Revenue Engine) ---------------------------------------------
# Required by pipeline/fetch_hubspot_data.py. Create a Private App in HubSpot
# (Settings -> Integrations -> Private Apps) with read scopes:
# crm.objects.contacts.read, crm.objects.companies.read, crm.objects.deals.read,
# crm.schemas.deals.read, and forms (optional). Copy its access token here and
# add it as the GitHub secret HUBSPOT_TOKEN. Never commit the real value.
HUBSPOT_TOKEN=

# --- Discord community analytics ------------------------------------------
# Used by fetch-discord.mjs (writes data/discord.json). Create a bot at
# discord.com/developers -> your app -> Bot (enable the Server Members
# Intent), invite it to the server, and copy the Bot Token. DISCORD_GUILD_ID
# is the server ID (enable Developer Mode -> right-click server -> Copy ID).
# Add both as GitHub secrets. Never commit the real values.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# --- GA4 website analytics (Acquisition tab, Phase 2) ---------------------
# Used by fetch-ga4.mjs (writes data/ga4.json). Create a Google Cloud service
# account, enable the Google Analytics Data API, and grant the service account
# "Viewer" on the GA4 property. GA4_PROPERTY_ID is the numeric property id
# (Admin -> Property Settings). GA4_SA_KEY is the FULL service-account JSON key
# pasted as a single secret. Add both as GitHub secrets. Never commit real values.
GA4_PROPERTY_ID=
GA4_SA_KEY=

# --- Slack daily summary (optional) ---------------------------------------
# Used by pipeline/post_slack_summary.py. Get this from api.slack.com/apps
# -> your app -> Incoming Webhooks -> Add New Webhook to Workspace. Leave
# blank to skip Slack posting entirely (the GitHub Action step for it is
# automatically skipped when this isn't set).
SLACK_WEBHOOK_URL=

# Optional — included as a link in the Slack summary. Defaults to the
# deployed Vercel URL if left blank; only needed if that URL changes.
DASHBOARD_URL=
