# Copy this file to .env and fill in real values locally.
# NEVER commit a file containing real credentials — .env is gitignored.
# For GitHub Actions, set these under Settings -> Secrets and variables ->
# Actions -> New repository secret (same names, one secret each). Do not
# put real values in this file or anywhere else in the repo.

# --- X (Twitter) API — OAuth 1.0a user context ---------------------------
# Required by pipeline/fetch_x_data.py and diagnostics/check_x_auth.py.
# Get these from developer.x.com -> your App -> Keys and Tokens.
# Generate the Access Token/Secret AFTER setting the app's permissions
# (Read, or Read+Write if you'll post too) — tokens generated before a
# permission change are invalid and must be regenerated.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Optional — only needed if/when a bearer-token (app-only) flow is used
# instead of/alongside OAuth 1.0a. Not required by the current pipeline.
X_BEARER_TOKEN=

# --- Instagram (Phase 2, not used yet) ------------------------------------
# Placeholder so the env shape is ready when the Instagram data source is
# added. Leave blank for now.
