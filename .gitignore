# Secrets
.env
.env.local

# Real pipeline output (the GitHub Action force-adds this file when
# committing the daily refresh — see .github/workflows/daily-refresh.yml —
# but local/manual runs shouldn't get committed accidentally).
data/x_latest.json

# Build-time copy of data/ that the Vite dev/build script generates so the
# web app can fetch it as a static asset. Regenerated by `npm run dev`/`build`.
web/public/data/

# Real credentials pasted into a Word doc during setup — never commit this.
Keys.docx
~$Keys.docx

# Cowork task brief — not part of the project, doesn't need to be in git.
cowork-dashboard-brief.md

# Node / web
web/node_modules/
node_modules/
web/dist/
dist/

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
.vscode/
