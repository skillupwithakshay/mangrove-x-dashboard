# Secrets
.env
.env.local

# Real pipeline output (the GitHub Action force-adds these files when
# committing the daily refresh — see .github/workflows/daily-refresh.yml —
# but local/manual runs shouldn't get committed accidentally). The committed
# *.sample.json files serve as the deployed fallback until the Action runs.
data/x_latest.json
data/youtube_latest.json
data/instagram_latest.json
data/tiktok_latest.json
data/linkedin_latest.json
data/pypi_latest.json
data/discord.json
data/ga4.json
data/funnel.json
# NOTE: data/hubspot.json (fetch-hubspot.mjs output) is intentionally NOT
# ignored — it holds real, non-PII CRM aggregates and is committed so the
# Revenue Engine renders immediately; the daily Action refreshes it in place.
# data/discord.json (fetch-discord.mjs output) IS ignored for local runs but
# force-added by the daily Action; data/discord.sample.json is the committed
# fallback the UI renders (badged SAMPLE) until the first real run.

# Follower-count time series accumulated by the X pipeline. Gitignored for
# local runs, but the daily Action force-adds it (see daily-refresh.yml) so
# history persists in the repo and grows one point per day.
data/x_followers_history.json
data/linkedin_followers_history.json

# Build-time copy of data/ that the Vite dev/build script generates so the
# web app can fetch it as a static asset. Regenerated by `npm run dev`/`build`.
web/public/data/

# Real credentials pasted into a Word doc during setup — never commit this.
Keys.docx
~$Keys.docx

# Cowork task brief — not part of the project, doesn't need to be in git.
cowork-dashboard-brief.md

# Node / web
web/node_modules/
node_modules/
web/dist/
dist/
# Transient Vite config-load artifacts
web/vite.config.js.timestamp-*.mjs

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
.vscode/

# Raw LinkedIn admin exports (source for build_linkedin_from_export.py).
# Only the derived data/linkedin_latest.json is committed.
data/linkedin_exports/
